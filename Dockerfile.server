FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*
COPY pyproject.toml .
RUN pip install --no-cache-dir ".[server]"
COPY server/ ./server/
RUN mkdir -p /app/uploads
EXPOSE 8000
CMD ["python", "-m", "server.main"]
